diff --git a/packages/supabase/supabase/migrations/20260512120000_core_1993_ride_validation_schema.sql b/packages/supabase/supabase/migrations/20260512120000_core_1993_ride_validation_schema.sql
new file mode 100644
index 000000000..a0e170ef1
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512120000_core_1993_ride_validation_schema.sql
@@ -0,0 +1,63 @@
+-- CORE-1993: JourneyValidationSummary schema — verdict table, basic-checks table, vehicle FK on Ride
+
+-- 1. JourneyValidationSummary — one verdict per journey (terminal verdict in checks → CAE → summary pipeline)
+CREATE TABLE "public"."JourneyValidationSummary" (
+  "id" uuid NOT NULL DEFAULT gen_random_uuid(),
+  "journey_id" uuid NOT NULL,
+  "status" text NOT NULL DEFAULT 'pending'
+    CHECK ("status" IN ('pending', 'valid', 'invalid')),
+  "rule_version" text NOT NULL,
+  "validated_at" timestamp with time zone,
+  "created_at" timestamp with time zone NOT NULL DEFAULT now(),
+  CONSTRAINT "JourneyValidationSummary_pkey" PRIMARY KEY ("id"),
+  CONSTRAINT "JourneyValidationSummary_journey_id_fkey"
+    FOREIGN KEY ("journey_id") REFERENCES "public"."Journey"("id") ON DELETE CASCADE,
+  CONSTRAINT "JourneyValidationSummary_journey_id_key" UNIQUE ("journey_id")
+);
+
+ALTER TABLE "public"."JourneyValidationSummary" ENABLE ROW LEVEL SECURITY;
+
+CREATE INDEX "JourneyValidationSummary_status_idx"
+  ON "public"."JourneyValidationSummary" ("status");
+
+-- 2. JourneyValidationBasicChecks — one row per summary, 10 check columns
+CREATE TABLE "public"."JourneyValidationBasicChecks" (
+  "id" uuid NOT NULL DEFAULT gen_random_uuid(),
+  "journey_validation_summary_id" uuid NOT NULL,
+  "distance_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("distance_check" IN ('pass', 'fail', 'warning', 'pending')),
+  "duration_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("duration_check" IN ('pass', 'fail', 'warning', 'pending')),
+  "speed_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("speed_check" IN ('pass', 'fail', 'warning', 'pending')),
+  "gps_quality_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("gps_quality_check" IN ('pass', 'fail', 'warning', 'pending')),
+  "route_match_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("route_match_check" IN ('pass', 'fail', 'warning', 'pending')),
+  "participant_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("participant_check" IN ('pass', 'fail', 'pending')),
+  "vehicle_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("vehicle_check" IN ('pass', 'fail', 'pending')),
+  "time_window_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("time_window_check" IN ('pass', 'fail', 'pending')),
+  "duplicate_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("duplicate_check" IN ('pass', 'fail', 'pending')),
+  "journey_proximity_check" text NOT NULL DEFAULT 'pending'
+    CHECK ("journey_proximity_check" IN ('pass', 'fail', 'pending')),
+  "detail" jsonb,
+  "created_at" timestamp with time zone NOT NULL DEFAULT now(),
+  CONSTRAINT "JourneyValidationBasicChecks_pkey" PRIMARY KEY ("id"),
+  CONSTRAINT "JourneyValidationBasicChecks_journey_validation_summary_id_fkey"
+    FOREIGN KEY ("journey_validation_summary_id") REFERENCES "public"."JourneyValidationSummary"("id") ON DELETE CASCADE,
+  CONSTRAINT "JourneyValidationBasicChecks_journey_validation_summary_id_key" UNIQUE ("journey_validation_summary_id")
+);
+
+ALTER TABLE "public"."JourneyValidationBasicChecks" ENABLE ROW LEVEL SECURITY;
+
+-- 3. Add vehicle_profile_id FK on Ride
+ALTER TABLE "public"."Ride"
+  ADD COLUMN "vehicle_profile_id" uuid
+    REFERENCES "public"."VehicleProfile"("id") ON DELETE SET NULL;
+
+CREATE INDEX "Ride_vehicle_profile_id_idx"
+  ON "public"."Ride" ("vehicle_profile_id");
diff --git a/packages/supabase/supabase/migrations/20260512120100_core_1993_ride_validation_rls_and_vehicle_autoset.sql b/packages/supabase/supabase/migrations/20260512120100_core_1993_ride_validation_rls_and_vehicle_autoset.sql
new file mode 100644
index 000000000..5c91dbff7
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512120100_core_1993_ride_validation_rls_and_vehicle_autoset.sql
@@ -0,0 +1,170 @@
+-- CORE-1993: RLS policies for JourneyValidationSummary/JourneyValidationBasicChecks + vehicle auto-set in journey_start_intent
+
+-- ============================================================
+-- JourneyValidationSummary RLS
+-- ============================================================
+REVOKE ALL ON "public"."JourneyValidationSummary" FROM public, anon, authenticated;
+GRANT SELECT ON "public"."JourneyValidationSummary" TO authenticated;
+GRANT ALL ON "public"."JourneyValidationSummary" TO service_role;
+
+CREATE POLICY "Journey owner or participant can read JourneyValidationSummary"
+  ON "public"."JourneyValidationSummary"
+  FOR SELECT
+  TO authenticated
+  USING (
+    EXISTS (
+      SELECT 1 FROM "public"."Journey" j
+      JOIN "public"."Ride" r ON r.id = j.ride_id
+      WHERE j.id = "journey_id"
+        AND (
+          r.owner_id = (SELECT auth.uid())
+          OR EXISTS (
+            SELECT 1 FROM "public"."RideParticipant" rp
+            WHERE rp.ride_id = r.id
+              AND rp.profile_id = (SELECT auth.uid())
+          )
+        )
+    )
+  );
+
+CREATE POLICY "Service role full access JourneyValidationSummary"
+  ON "public"."JourneyValidationSummary"
+  FOR ALL
+  TO service_role
+  USING (true)
+  WITH CHECK (true);
+
+-- ============================================================
+-- JourneyValidationBasicChecks RLS
+-- ============================================================
+REVOKE ALL ON "public"."JourneyValidationBasicChecks" FROM public, anon, authenticated;
+GRANT SELECT ON "public"."JourneyValidationBasicChecks" TO authenticated;
+GRANT ALL ON "public"."JourneyValidationBasicChecks" TO service_role;
+
+CREATE POLICY "Journey owner or participant can read JourneyValidationBasicChecks"
+  ON "public"."JourneyValidationBasicChecks"
+  FOR SELECT
+  TO authenticated
+  USING (
+    EXISTS (
+      SELECT 1 FROM "public"."JourneyValidationSummary" jvs
+      JOIN "public"."Journey" j ON j.id = jvs.journey_id
+      JOIN "public"."Ride" r ON r.id = j.ride_id
+      WHERE jvs.id = "journey_validation_summary_id"
+        AND (
+          r.owner_id = (SELECT auth.uid())
+          OR EXISTS (
+            SELECT 1 FROM "public"."RideParticipant" rp
+            WHERE rp.ride_id = r.id
+              AND rp.profile_id = (SELECT auth.uid())
+          )
+        )
+    )
+  );
+
+CREATE POLICY "Service role full access JourneyValidationBasicChecks"
+  ON "public"."JourneyValidationBasicChecks"
+  FOR ALL
+  TO service_role
+  USING (true)
+  WITH CHECK (true);
+
+-- ============================================================
+-- Redefine journey_start_intent — add vehicle auto-set
+-- ============================================================
+CREATE OR REPLACE FUNCTION public.journey_start_intent(
+  p_ride_id bigint,
+  p_idempotency_key text DEFAULT NULL
+)
+RETURNS public."Journey"
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path TO 'public', 'private', 'pg_temp'
+AS $$
+DECLARE
+  _uid uuid := auth.uid();
+  _created_at timestamp;
+  _journey public."Journey"%ROWTYPE;
+  _driver_profile_id uuid;
+BEGIN
+  IF _uid IS NULL THEN
+    RAISE EXCEPTION 'journey_start_intent_denied: user not authenticated';
+  END IF;
+
+  SELECT r.created_at
+    INTO _created_at
+  FROM public."Ride" r
+  WHERE r.id = p_ride_id
+    AND (
+      r.owner_id = _uid
+      OR public.is_ride_driver(p_ride_id, _uid)
+    );
+
+  IF NOT FOUND THEN
+    RAISE EXCEPTION 'journey_start_intent_denied: ride not found or caller is not driver';
+  END IF;
+
+  IF _created_at IS NOT NULL AND NOT public.ride_within_24h(_created_at) THEN
+    RAISE EXCEPTION 'journey_start_intent_denied: ride too old to update';
+  END IF;
+
+  IF p_idempotency_key IS NOT NULL THEN
+    SELECT j.*
+      INTO _journey
+    FROM public."Journey" j
+    INNER JOIN public."JourneyLifecycleTransition" transition
+      ON transition.journey_id = j.id
+    WHERE j.ride_id = p_ride_id
+      AND transition.idempotency_key = p_idempotency_key;
+
+    IF FOUND THEN
+      RETURN _journey;
+    END IF;
+  END IF;
+
+  _journey := private.transition_journey_lifecycle(
+    p_ride_id := p_ride_id,
+    p_to_lifecycle := 'active'::public."JourneyLifecycle",
+    p_actor_profile_id := _uid,
+    p_actor_type := 'authenticated',
+    p_metadata := jsonb_build_object('intent', 'start'),
+    p_idempotency_key := p_idempotency_key
+  );
+
+  -- Auto-set driver's primary vehicle on ride (idempotent: only if NULL)
+  SELECT rp.profile_id
+    INTO _driver_profile_id
+  FROM public."RideParticipant" rp
+  WHERE rp.ride_id = p_ride_id
+    AND rp.type = 'DRIVER'::"TripMode"
+  LIMIT 1;
+
+  IF _driver_profile_id IS NOT NULL THEN
+    UPDATE public."Ride"
+    SET vehicle_profile_id = (
+      SELECT vp.id FROM public."VehicleProfile" vp
+      WHERE vp.profile_id = _driver_profile_id
+        AND vp.is_primary = true
+      LIMIT 1
+    )
+    WHERE id = p_ride_id
+      AND vehicle_profile_id IS NULL;
+  END IF;
+
+  INSERT INTO public."JourneyParticipantSession" (
+    journey_id,
+    user_id,
+    joined_at
+  )
+  VALUES (
+    _journey.id,
+    _uid,
+    now()
+  )
+  ON CONFLICT ("journey_id", "user_id")
+    WHERE left_at IS NULL
+    DO NOTHING;
+
+  RETURN _journey;
+END;
+$$;
diff --git a/packages/supabase/supabase/migrations/20260512130000_core_1994_schema_updates.sql b/packages/supabase/supabase/migrations/20260512130000_core_1994_schema_updates.sql
