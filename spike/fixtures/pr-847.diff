+-- CORE-1994: Schema updates to CORE-1993 tables (pre-production, safe to alter)
+
+-- 1. Column renames on JourneyValidationBasicChecks
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "duration_check" TO "movement_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "time_window_check" TO "gps_coverage_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "distance_check" TO "distance_plausible_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "route_match_check" TO "route_consistency_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "participant_check" TO "min_participants_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  RENAME COLUMN "vehicle_check" TO "vehicle_on_record_check";
+
+-- 2. Add 'warning' to gps_coverage_check constraint (was pass|fail|pending)
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_time_window_check_check";
+
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_gps_coverage_check_check"
+    CHECK ("gps_coverage_check" IN ('pass', 'fail', 'warning', 'pending'));
+
+-- 3. Rename remaining check constraints to match new column names
+
+-- duration_check -> movement_check (has 'warning')
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_duration_check_check";
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_movement_check_check"
+    CHECK ("movement_check" IN ('pass', 'fail', 'warning', 'pending'));
+
+-- distance_check -> distance_plausible_check (has 'warning')
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_distance_check_check";
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_distance_plausible_check_check"
+    CHECK ("distance_plausible_check" IN ('pass', 'fail', 'warning', 'pending'));
+
+-- route_match_check -> route_consistency_check (has 'warning')
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_route_match_check_check";
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_route_consistency_check_check"
+    CHECK ("route_consistency_check" IN ('pass', 'fail', 'warning', 'pending'));
+
+-- participant_check -> min_participants_check (no 'warning')
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_participant_check_check";
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_min_participants_check_check"
+    CHECK ("min_participants_check" IN ('pass', 'fail', 'pending'));
+
+-- vehicle_check -> vehicle_on_record_check (no 'warning')
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  DROP CONSTRAINT "JourneyValidationBasicChecks_vehicle_check_check";
+ALTER TABLE "public"."JourneyValidationBasicChecks"
+  ADD CONSTRAINT "JourneyValidationBasicChecks_vehicle_on_record_check_check"
+    CHECK ("vehicle_on_record_check" IN ('pass', 'fail', 'pending'));
+
+-- 4. Update JourneyValidationSummary.status constraint
+ALTER TABLE "public"."JourneyValidationSummary"
+  DROP CONSTRAINT "JourneyValidationSummary_status_check";
+
+ALTER TABLE "public"."JourneyValidationSummary"
+  ADD CONSTRAINT "JourneyValidationSummary_status_check"
+    CHECK ("status" IN ('pending', 'passed', 'failed', 'needs_review'));
diff --git a/packages/supabase/supabase/migrations/20260512130100_core_1994_validation_functions.sql b/packages/supabase/supabase/migrations/20260512130100_core_1994_validation_functions.sql
new file mode 100644
index 000000000..2bf9f045c
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512130100_core_1994_validation_functions.sql
@@ -0,0 +1,544 @@
+-- CORE-1994: Validation functions — journey_run_validation_checks & journey_finalize_validation
+
+--------------------------------------------------------------------------------
+-- Function 1: journey_run_validation_checks
+-- Runs 10 checks against processed journey data, upserts JourneyValidationSummary +
+-- JourneyValidationBasicChecks rows.
+--------------------------------------------------------------------------------
+CREATE OR REPLACE FUNCTION private.journey_run_validation_checks(p_journey_id uuid)
+RETURNS void
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path TO 'public', 'private', 'pg_temp'
+AS $$
+DECLARE
+  _journey         public."Journey"%ROWTYPE;
+  _validation_id   uuid;
+
+  -- GPS aggregates
+  _gps_min_captured  timestamp with time zone;
+  _gps_max_captured  timestamp with time zone;
+  _gps_avg_accuracy  double precision;
+  _gps_count         bigint;
+  _first_lat         double precision;
+  _first_lon         double precision;
+
+  -- check results
+  _min_participants_check    text := 'pending';
+  _gps_coverage_check        text := 'pending';
+  _gps_quality_check         text := 'pending';
+  _movement_check            text := 'pending';
+  _speed_check               text := 'pending';
+  _distance_plausible_check  text := 'pending';
+  _route_consistency_check   text := 'pending';
+  _duplicate_check           text := 'pending';
+  _vehicle_on_record_check   text := 'pending';
+  _journey_proximity_check   text := 'pending';
+
+  -- detail jsonb
+  _detail jsonb := '{}'::jsonb;
+
+  -- intermediates
+  _participant_count   bigint;
+  _coverage_ratio      double precision;
+  _journey_duration_s  double precision;
+  _max_displacement_km double precision;
+  _max_speed_kmh       double precision;
+  _total_km            numeric;
+  _vehicle_profile_id  uuid;
+  _duplicate_ride_id   integer;
+
+  -- route consistency
+  _seg_start_lat  double precision;
+  _seg_start_lon  double precision;
+  _seg_end_lat    double precision;
+  _seg_end_lon    double precision;
+  _gps_first_lat  double precision;
+  _gps_first_lon  double precision;
+  _gps_last_lat   double precision;
+  _gps_last_lon   double precision;
+  _start_dist_km  double precision;
+  _end_dist_km    double precision;
+  _max_route_dist double precision;
+
+  -- journey proximity
+  _prev_journey_id      uuid;
+  _prev_ended_at        timestamp with time zone;
+  _prev_end_lat         double precision;
+  _prev_end_lon         double precision;
+  _prox_time_gap_min    double precision;
+  _prox_distance_km     double precision;
+  _driver_id            uuid;
+BEGIN
+  -- Load journey
+  SELECT * INTO _journey
+  FROM public."Journey"
+  WHERE id = p_journey_id;
+
+  IF NOT FOUND THEN
+    RAISE EXCEPTION 'journey_validation: journey not found: %', p_journey_id;
+  END IF;
+
+  ---------------------------------------------------------------------------
+  -- Upsert JourneyValidationSummary early so the row exists if a check throws
+  ---------------------------------------------------------------------------
+  INSERT INTO public."JourneyValidationSummary" (journey_id, status, rule_version)
+  VALUES (p_journey_id, 'pending', 'v1')
+  ON CONFLICT (journey_id) DO UPDATE
+    SET status = 'pending',
+        rule_version = 'v1',
+        validated_at = NULL
+  RETURNING id INTO _validation_id;
+
+  ---------------------------------------------------------------------------
+  -- CHECK 1: min_participants_check
+  ---------------------------------------------------------------------------
+  SELECT COUNT(DISTINCT ps.user_id) INTO _participant_count
+  FROM public."JourneyParticipantSession" ps
+  WHERE ps.journey_id = _journey.id;
+
+  IF _participant_count >= 2 THEN
+    _min_participants_check := 'pass';
+  ELSE
+    _min_participants_check := 'fail';
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'min_participants_check', jsonb_build_object('participant_count', _participant_count)
+  );
+
+  ---------------------------------------------------------------------------
+  -- GPS aggregates (used by checks 2-5)
+  ---------------------------------------------------------------------------
+  SELECT
+    MIN(g.captured_at),
+    MAX(g.captured_at),
+    AVG(g.accuracy) FILTER (WHERE g.accuracy IS NOT NULL),
+    COUNT(*)
+  INTO _gps_min_captured, _gps_max_captured, _gps_avg_accuracy, _gps_count
+  FROM public."JourneyRawGPS" g
+  WHERE g.ride_id = _journey.ride_id;
+
+  ---------------------------------------------------------------------------
+  -- CHECK 2: gps_coverage_check
+  ---------------------------------------------------------------------------
+  _journey_duration_s := EXTRACT(EPOCH FROM (_journey.ended_at - _journey.created_at));
+
+  IF _journey_duration_s > 0 AND _gps_count > 0 THEN
+    _coverage_ratio := EXTRACT(EPOCH FROM (_gps_max_captured - _gps_min_captured))
+                       / _journey_duration_s;
+
+    IF _coverage_ratio >= 0.8 THEN
+      _gps_coverage_check := 'pass';
+    ELSIF _coverage_ratio >= 0.5 THEN
+      _gps_coverage_check := 'warning';
+    ELSE
+      _gps_coverage_check := 'fail';
+    END IF;
+  ELSE
+    _gps_coverage_check := 'fail';
+    _coverage_ratio := 0;
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'gps_coverage_check', jsonb_build_object(
+      'coverage_ratio', ROUND(_coverage_ratio::numeric, 4),
+      'gps_span_seconds', EXTRACT(EPOCH FROM (_gps_max_captured - _gps_min_captured)),
+      'journey_duration_seconds', _journey_duration_s
+    )
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 3: gps_quality_check
+  ---------------------------------------------------------------------------
+  IF _gps_avg_accuracy IS NOT NULL THEN
+    IF _gps_avg_accuracy < 50 THEN
+      _gps_quality_check := 'pass';
+    ELSIF _gps_avg_accuracy <= 100 THEN
+      _gps_quality_check := 'warning';
+    ELSE
+      _gps_quality_check := 'fail';
+    END IF;
+  ELSE
+    -- no accuracy data available, pass (not all devices report it)
+    _gps_quality_check := 'pass';
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'gps_quality_check', jsonb_build_object('avg_accuracy_m', _gps_avg_accuracy)
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 4: movement_check (max displacement from first point >= 1km)
+  ---------------------------------------------------------------------------
+  IF _gps_count > 0 THEN
+    -- Get first GPS point
+    SELECT g.latitude, g.longitude INTO _first_lat, _first_lon
+    FROM public."JourneyRawGPS" g
+    WHERE g.ride_id = _journey.ride_id
+    ORDER BY g.captured_at ASC, g.id ASC
+    LIMIT 1;
+
+    -- Max haversine from first point
+    SELECT MAX(private.journey_haversine_km(_first_lat, _first_lon, g.latitude, g.longitude))
+    INTO _max_displacement_km
+    FROM public."JourneyRawGPS" g
+    WHERE g.ride_id = _journey.ride_id;
+
+    IF _max_displacement_km >= 1 THEN
+      _movement_check := 'pass';
+    ELSE
+      _movement_check := 'fail';
+    END IF;
+  ELSE
+    _movement_check := 'fail';
+    _max_displacement_km := 0;
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'movement_check', jsonb_build_object('max_displacement_km', ROUND(_max_displacement_km::numeric, 3))
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 5: speed_check (no consecutive point-to-point speed > 200 km/h)
+  ---------------------------------------------------------------------------
+  IF _gps_count >= 2 THEN
+    SELECT MAX(
+      CASE
+        WHEN EXTRACT(EPOCH FROM (g.captured_at - g.prev_captured_at)) > 0 THEN
+          private.journey_haversine_km(g.prev_lat, g.prev_lon, g.latitude, g.longitude)
+          / (EXTRACT(EPOCH FROM (g.captured_at - g.prev_captured_at)) / 3600.0)
+        ELSE 0
+      END
+    ) INTO _max_speed_kmh
+    FROM (
+      SELECT
+        g2.latitude,
+        g2.longitude,
+        g2.captured_at,
+        LAG(g2.latitude) OVER (ORDER BY g2.captured_at, g2.id) AS prev_lat,
+        LAG(g2.longitude) OVER (ORDER BY g2.captured_at, g2.id) AS prev_lon,
+        LAG(g2.captured_at) OVER (ORDER BY g2.captured_at, g2.id) AS prev_captured_at
+      FROM public."JourneyRawGPS" g2
+      WHERE g2.ride_id = _journey.ride_id
+    ) g
+    WHERE g.prev_captured_at IS NOT NULL;
+
+    IF _max_speed_kmh > 200 THEN
+      _speed_check := 'fail';
+    ELSE
+      _speed_check := 'pass';
+    END IF;
+  ELSE
+    _speed_check := 'pass';
+    _max_speed_kmh := 0;
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'speed_check', jsonb_build_object('max_speed_kmh', ROUND(_max_speed_kmh::numeric, 1))
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 6: distance_plausible_check (Ride.total_km between 0.5 and 1000)
+  ---------------------------------------------------------------------------
+  SELECT r.total_km, r.vehicle_profile_id
+  INTO _total_km, _vehicle_profile_id
+  FROM public."Ride" r
+  WHERE r.id = _journey.ride_id;
+
+  IF _total_km IS NOT NULL AND _total_km > 0.5 AND _total_km < 1000 THEN
+    _distance_plausible_check := 'pass';
+  ELSE
+    _distance_plausible_check := 'fail';
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'distance_plausible_check', jsonb_build_object('total_km', _total_km)
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 7: route_consistency_check
+  -- Compare first/last GPS clusters vs first/last segment endpoints
+  ---------------------------------------------------------------------------
+  -- First and last GPS points
+  SELECT g.latitude, g.longitude INTO _gps_first_lat, _gps_first_lon
+  FROM public."JourneyRawGPS" g
+  WHERE g.ride_id = _journey.ride_id
+  ORDER BY g.captured_at ASC, g.id ASC
+  LIMIT 1;
+
+  SELECT g.latitude, g.longitude INTO _gps_last_lat, _gps_last_lon
+  FROM public."JourneyRawGPS" g
+  WHERE g.ride_id = _journey.ride_id
+  ORDER BY g.captured_at DESC, g.id DESC
+  LIMIT 1;
+
+  -- First segment start and last segment end
+  SELECT s.start_point_latitude, s.start_point_longitude
+  INTO _seg_start_lat, _seg_start_lon
+  FROM public."JourneySegment" s
+  WHERE s.journey_id = _journey.id
+  ORDER BY s.sequence ASC
+  LIMIT 1;
+
+  SELECT s.end_point_latitude, s.end_point_longitude
+  INTO _seg_end_lat, _seg_end_lon
+  FROM public."JourneySegment" s
+  WHERE s.journey_id = _journey.id
+  ORDER BY s.sequence DESC
+  LIMIT 1;
+
+  IF _gps_first_lat IS NOT NULL AND _seg_start_lat IS NOT NULL THEN
+    _start_dist_km := private.journey_haversine_km(
+      _gps_first_lat, _gps_first_lon, _seg_start_lat, _seg_start_lon
+    );
+    _end_dist_km := private.journey_haversine_km(
+      _gps_last_lat, _gps_last_lon, _seg_end_lat, _seg_end_lon
+    );
+    _max_route_dist := GREATEST(_start_dist_km, _end_dist_km);
+
+    IF _max_route_dist < 2 THEN
+      _route_consistency_check := 'pass';
+    ELSIF _max_route_dist <= 5 THEN
+      _route_consistency_check := 'warning';
+    ELSE
+      _route_consistency_check := 'fail';
+    END IF;
+  ELSE
+    _route_consistency_check := 'fail';
+    _max_route_dist := NULL;
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'route_consistency_check', jsonb_build_object(
+      'start_distance_km', ROUND(COALESCE(_start_dist_km, 0)::numeric, 3),
+      'end_distance_km', ROUND(COALESCE(_end_dist_km, 0)::numeric, 3),
+      'max_distance_km', ROUND(COALESCE(_max_route_dist, 0)::numeric, 3)
+    )
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 8: duplicate_check
+  -- Any other ride with overlapping participants within +-30min
+  ---------------------------------------------------------------------------
+  SELECT other_r.id INTO _duplicate_ride_id
+  FROM public."Ride" other_r
+  INNER JOIN public."Journey" other_j ON other_j.ride_id = other_r.id
+  INNER JOIN public."RideParticipant" other_rp ON other_rp.ride_id = other_r.id
+  INNER JOIN public."RideParticipant" this_rp ON this_rp.ride_id = _journey.ride_id
+    AND this_rp.profile_id = other_rp.profile_id
+  WHERE other_r.id <> _journey.ride_id
+    AND other_j.lifecycle = 'processed'::public."JourneyLifecycle"
+    AND other_j.created_at BETWEEN (_journey.created_at - interval '30 minutes')
+                                AND (_journey.created_at + interval '30 minutes')
+  LIMIT 1;
+
+  IF _duplicate_ride_id IS NOT NULL THEN
+    _duplicate_check := 'fail';
+  ELSE
+    _duplicate_check := 'pass';
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'duplicate_check', jsonb_build_object('duplicate_ride_id', _duplicate_ride_id)
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 9: vehicle_on_record_check
+  ---------------------------------------------------------------------------
+  IF _vehicle_profile_id IS NOT NULL THEN
+    _vehicle_on_record_check := 'pass';
+  ELSE
+    _vehicle_on_record_check := 'fail';
+  END IF;
+
+  _detail := _detail || jsonb_build_object(
+    'vehicle_on_record_check', jsonb_build_object('vehicle_profile_id', _vehicle_profile_id)
+  );
+
+  ---------------------------------------------------------------------------
+  -- CHECK 10: journey_proximity_check
+  -- Driver's most recent other journey vs current journey first GPS point
+  ---------------------------------------------------------------------------
+  -- Get the driver (ride owner)
+  SELECT r.owner_id INTO _driver_id
+  FROM public."Ride" r
+  WHERE r.id = _journey.ride_id;
+
+  IF _driver_id IS NOT NULL AND _gps_first_lat IS NOT NULL THEN
+    SELECT
+      prev_j.id,
+      prev_j.ended_at,
+      prev_seg.end_point_latitude,
+      prev_seg.end_point_longitude
+    INTO _prev_journey_id, _prev_ended_at, _prev_end_lat, _prev_end_lon
+    FROM public."Journey" prev_j
+    INNER JOIN public."Ride" prev_r ON prev_r.id = prev_j.ride_id
+    INNER JOIN public."JourneySegment" prev_seg
+      ON prev_seg.journey_id = prev_j.id
+    WHERE prev_r.owner_id = _driver_id
+      AND prev_j.id <> _journey.id
+      AND prev_j.ended_at IS NOT NULL
+      AND prev_j.ended_at < _journey.created_at
+    ORDER BY prev_j.ended_at DESC, prev_seg.sequence DESC
+    LIMIT 1;
+
+    IF _prev_journey_id IS NOT NULL THEN
+      _prox_time_gap_min := EXTRACT(EPOCH FROM (_journey.created_at - _prev_ended_at)) / 60.0;
+      _prox_distance_km := private.journey_haversine_km(
+        _prev_end_lat, _prev_end_lon, _gps_first_lat, _gps_first_lon
+      );
+
+      IF _prox_time_gap_min <= 20 AND _prox_distance_km <= 5 THEN
+        _journey_proximity_check := 'fail';
+      ELSE
+        _journey_proximity_check := 'pass';
+      END IF;
+
+      _detail := _detail || jsonb_build_object(
+        'journey_proximity_check', jsonb_build_object(
+          'previous_journey_id', _prev_journey_id,
+          'time_gap_minutes', ROUND(_prox_time_gap_min::numeric, 1),
+          'distance_km', ROUND(_prox_distance_km::numeric, 3),
+          'prev_end_lat', _prev_end_lat,
+          'prev_end_lon', _prev_end_lon,
+          'current_start_lat', _gps_first_lat,
+          'current_start_lon', _gps_first_lon
+        )
+      );
+    ELSE
+      _journey_proximity_check := 'pass';
+      _detail := _detail || jsonb_build_object(
+        'journey_proximity_check', jsonb_build_object('previous_journey_id', NULL)
+      );
+    END IF;
+  ELSE
+    _journey_proximity_check := 'pass';
+    _detail := _detail || jsonb_build_object(
+      'journey_proximity_check', jsonb_build_object('previous_journey_id', NULL)
+    );
+  END IF;
+
+  ---------------------------------------------------------------------------
+  -- Upsert JourneyValidationBasicChecks
+  ---------------------------------------------------------------------------
+  INSERT INTO public."JourneyValidationBasicChecks" (
+    journey_validation_summary_id,
+    min_participants_check,
+    gps_coverage_check,
+    gps_quality_check,
+    movement_check,
+    speed_check,
+    distance_plausible_check,
+    route_consistency_check,
+    duplicate_check,
+    vehicle_on_record_check,
+    journey_proximity_check,
+    detail
+  )
+  VALUES (
+    _validation_id,
+    _min_participants_check,
+    _gps_coverage_check,
+    _gps_quality_check,
+    _movement_check,
+    _speed_check,
+    _distance_plausible_check,
+    _route_consistency_check,
+    _duplicate_check,
+    _vehicle_on_record_check,
+    _journey_proximity_check,
+    _detail
+  )
+  ON CONFLICT (journey_validation_summary_id) DO UPDATE
+    SET min_participants_check    = EXCLUDED.min_participants_check,
+        gps_coverage_check        = EXCLUDED.gps_coverage_check,
+        gps_quality_check         = EXCLUDED.gps_quality_check,
+        movement_check            = EXCLUDED.movement_check,
+        speed_check               = EXCLUDED.speed_check,
+        distance_plausible_check  = EXCLUDED.distance_plausible_check,
+        route_consistency_check   = EXCLUDED.route_consistency_check,
+        duplicate_check           = EXCLUDED.duplicate_check,
+        vehicle_on_record_check   = EXCLUDED.vehicle_on_record_check,
+        journey_proximity_check   = EXCLUDED.journey_proximity_check,
+        detail                    = EXCLUDED.detail;
+END;
+$$;
+
+--------------------------------------------------------------------------------
+-- Function 2: journey_finalize_validation
+-- Reads checks, computes final verdict, updates JourneyValidationSummary.
+-- (CAE eligibility is folded in by CORE-1996, which updates this function to
+--  read JourneyCAEEligibility.status directly.)
+--------------------------------------------------------------------------------
+CREATE OR REPLACE FUNCTION private.journey_finalize_validation(p_journey_id uuid)
+RETURNS void
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path TO 'public', 'private', 'pg_temp'
+AS $$
+DECLARE
+  _validation_id uuid;
+  _checks        public."JourneyValidationBasicChecks"%ROWTYPE;
+  _status        text;
+  _has_fail      boolean := false;
+  _has_warning   boolean := false;
+BEGIN
+  -- Get validation summary id
+  SELECT jvs.id INTO _validation_id
+  FROM public."JourneyValidationSummary" jvs
+  WHERE jvs.journey_id = p_journey_id;
+
+  IF NOT FOUND THEN
+    RAISE EXCEPTION 'journey_finalize_validation: no validation row for journey %', p_journey_id;
+  END IF;
+
+  -- Load checks
+  SELECT * INTO _checks
+  FROM public."JourneyValidationBasicChecks" c
+  WHERE c.journey_validation_summary_id = _validation_id;
+
+  IF NOT FOUND THEN
+    RAISE EXCEPTION 'journey_finalize_validation: no checks row for journey %', p_journey_id;
+  END IF;
+
+  -- Evaluate fails
+  _has_fail := (
+       _checks.min_participants_check = 'fail'
+    OR _checks.gps_coverage_check = 'fail'
+    OR _checks.gps_quality_check = 'fail'
+    OR _checks.movement_check = 'fail'
+    OR _checks.speed_check = 'fail'
+    OR _checks.distance_plausible_check = 'fail'
+    OR _checks.route_consistency_check = 'fail'
+    OR _checks.duplicate_check = 'fail'
+    OR _checks.vehicle_on_record_check = 'fail'
+    OR _checks.journey_proximity_check = 'fail'
+  );
+
+  -- Evaluate warnings
+  _has_warning := (
+       _checks.gps_coverage_check = 'warning'
+    OR _checks.gps_quality_check = 'warning'
+    OR _checks.movement_check = 'warning'
+    OR _checks.speed_check = 'warning'
+    OR _checks.distance_plausible_check = 'warning'
+    OR _checks.route_consistency_check = 'warning'
+  );
+
+  -- Compute verdict
+  IF _has_fail THEN
+    _status := 'failed';
+  ELSIF _has_warning THEN
+    _status := 'needs_review';
+  ELSE
+    _status := 'passed';
+  END IF;
+
+  -- Update JourneyValidationSummary
+  UPDATE public."JourneyValidationSummary"
+  SET status = _status,
+      validated_at = now()
+  WHERE id = _validation_id;
+END;
+$$;
diff --git a/packages/supabase/supabase/migrations/20260512130200_core_1994_lifecycle_hook.sql b/packages/supabase/supabase/migrations/20260512130200_core_1994_lifecycle_hook.sql
new file mode 100644
index 000000000..8d0b9605f
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512130200_core_1994_lifecycle_hook.sql
@@ -0,0 +1,116 @@
+-- CORE-1994: Hook validation into journey_process_ended
+-- Validation runs after journey transitions to 'processed'.
+-- Failures are caught and do NOT fail the journey processing.
+-- Based on the late-GPS version from 20260508120000 (accepts both 'ended' and 'processed').
+
+CREATE OR REPLACE FUNCTION private.journey_process_ended(
+  p_ride_id bigint,
+  p_actor_profile_id uuid DEFAULT NULL,
+  p_idempotency_key text DEFAULT NULL
+)
+RETURNS public."Journey"
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path TO 'public', 'private', 'pg_temp'
+AS $$
+DECLARE
+  _journey public."Journey"%ROWTYPE;
+  _segments jsonb;
+  _total_km numeric := 0;
+BEGIN
+  SELECT * INTO _journey
+  FROM public."Journey"
+  WHERE ride_id = p_ride_id
+  FOR UPDATE;
+
+  IF NOT FOUND THEN
+    RAISE EXCEPTION 'journey_not_found: %', p_ride_id;
+  END IF;
+
+  IF _journey.lifecycle NOT IN ('ended'::public."JourneyLifecycle", 'processed'::public."JourneyLifecycle") THEN
+    RAISE EXCEPTION 'journey_process_invalid_lifecycle: %', _journey.lifecycle;
+  END IF;
+
+  _segments := private.journey_derive_segment_payload(p_ride_id);
+
+  IF jsonb_array_length(_segments) = 0 THEN
+    RAISE EXCEPTION 'segment_derivation_failed: no segments';
+  END IF;
+
+  PERFORM private.journey_replace_segments_internal(p_ride_id, _segments);
+
+  DELETE FROM public."JourneyParticipantSummary" summary
+  WHERE summary.journey_id = _journey.id;
+
+  INSERT INTO public."JourneyParticipantSummary" (
+    journey_id, user_id, total_distance_km, total_time_seconds, segment_count
+  )
+  SELECT
+    segment.journey_id,
+    participant.user_id,
+    COALESCE(SUM(segment.distance_km), 0),
+    COALESCE(SUM(GREATEST(0, EXTRACT(EPOCH FROM (segment.ended_at - segment.started_at)))::integer), 0),
+    COUNT(*)::integer
+  FROM public."JourneySegment" segment
+  INNER JOIN public."JourneySegmentParticipant" participant
+    ON participant.segment_id = segment.id
+  WHERE segment.journey_id = _journey.id
+  GROUP BY segment.journey_id, participant.user_id;
+
+  SELECT COALESCE(SUM(segment.distance_km), 0)
+    INTO _total_km
+  FROM public."JourneySegment" segment
+  WHERE segment.journey_id = _journey.id;
+
+  UPDATE public."Ride" ride
+  SET journey_flag = true,
+      total_km = _total_km
+  WHERE ride.id = p_ride_id;
+
+  -- Already-processed branch: update processed_at, skip lifecycle transition
+  IF _journey.lifecycle = 'processed'::public."JourneyLifecycle" THEN
+    UPDATE public."Journey"
+    SET processed_at = now(), updated_at = now()
+    WHERE id = _journey.id
+    RETURNING * INTO _journey;
+
+    -- Run validation checks (non-blocking: errors are caught and logged)
+    BEGIN
+      PERFORM private.journey_run_validation_checks(_journey.id);
+      PERFORM private.journey_finalize_validation(_journey.id);
+    EXCEPTION
+      WHEN OTHERS THEN
+        UPDATE public."JourneyValidationSummary"
+        SET status = 'pending', validated_at = NULL
+        WHERE journey_id = _journey.id;
+        RAISE WARNING 'journey_validation_error for ride %: % [%]', p_ride_id, SQLERRM, SQLSTATE;
+    END;
+
+    RETURN _journey;
+  END IF;
+
+  -- First-time processed: transition lifecycle
+  _journey := private.transition_journey_lifecycle(
+    p_ride_id := p_ride_id,
+    p_to_lifecycle := 'processed'::public."JourneyLifecycle",
+    p_actor_profile_id := p_actor_profile_id,
+    p_actor_type := CASE WHEN p_actor_profile_id IS NULL THEN 'system' ELSE 'authenticated' END,
+    p_metadata := jsonb_build_object('intent', 'process_end', 'total_km', _total_km),
+    p_idempotency_key := p_idempotency_key || ':processed'
+  );
+
+  -- Run validation checks (non-blocking: errors are caught and logged)
+  BEGIN
+    PERFORM private.journey_run_validation_checks(_journey.id);
+    PERFORM private.journey_finalize_validation(_journey.id);
+  EXCEPTION
+    WHEN OTHERS THEN
+      UPDATE public."JourneyValidationSummary"
+      SET status = 'pending', validated_at = NULL
+      WHERE journey_id = _journey.id;
+      RAISE WARNING 'journey_validation_error for ride %: % [%]', p_ride_id, SQLERRM, SQLSTATE;
+  END;
+
+  RETURN _journey;
+END;
+$$;
diff --git a/packages/supabase/supabase/migrations/20260512140000_core_1995_cae_eligibility_schema.sql b/packages/supabase/supabase/migrations/20260512140000_core_1995_cae_eligibility_schema.sql
new file mode 100644
index 000000000..fc748419f
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512140000_core_1995_cae_eligibility_schema.sql
@@ -0,0 +1,164 @@
+-- CORE-1995: CAE Eligibility schema — Spain TRA040/TRA030 eligibility layer
+-- Sits alongside JourneyValidationSummary/JourneyValidationBasicChecks. Step 2 of the pipeline.
+
+-- 1. JourneyCAEEligibility — one row per journey (via JourneyValidationSummary,
+-- which already holds UNIQUE(journey_id); the join through JourneyValidationSummary
+-- is the single source of truth for which journey a CAE row belongs to).
+CREATE TABLE "public"."JourneyCAEEligibility" (
+  "id" uuid NOT NULL DEFAULT gen_random_uuid(),
+  "journey_validation_summary_id" uuid NOT NULL,
+  "status" text NOT NULL
+    CHECK ("status" IN ('eligible', 'ineligible', 'needs_review')),
+  "ficha" text
+    CHECK ("ficha" IS NULL OR "ficha" IN ('TRA040', 'TRA030')),
+  "is_long_distance" boolean NOT NULL DEFAULT false,
+  "participant_count" integer NOT NULL,
+  "total_distance_km" numeric NOT NULL,
+  "regulation_version" text NOT NULL,
+  "c_factor_used" numeric NOT NULL,
+  "cef_ref_used" numeric NOT NULL,  -- writer (CORE-1996) must set explicitly; current TRA040 value is 0.705
+  "ineligibility_reasons" text[],
+  "origin_snapshot" jsonb,
+  "destination_snapshot" jsonb,
+  "vehicle_snapshot" jsonb,
+  "decided_at" timestamp with time zone NOT NULL DEFAULT now(),
+  "created_at" timestamp with time zone NOT NULL DEFAULT now(),
+  CONSTRAINT "JourneyCAEEligibility_pkey" PRIMARY KEY ("id"),
+  CONSTRAINT "JourneyCAEEligibility_journey_validation_summary_id_fkey"
+    FOREIGN KEY ("journey_validation_summary_id") REFERENCES "public"."JourneyValidationSummary"("id") ON DELETE CASCADE,
+  -- One CAE row per journey: piggy-backs on JourneyValidationSummary's UNIQUE(journey_id).
+  CONSTRAINT "JourneyCAEEligibility_journey_validation_summary_id_key" UNIQUE ("journey_validation_summary_id"),
+  -- Domain CHECKs.
+  CONSTRAINT "JourneyCAEEligibility_eligible_requires_ficha"
+    CHECK ("status" <> 'eligible' OR "ficha" IS NOT NULL),
+  CONSTRAINT "JourneyCAEEligibility_participant_count_nonneg"
+    CHECK ("participant_count" >= 1),
+  CONSTRAINT "JourneyCAEEligibility_eligible_needs_two_participants"
+    CHECK ("status" <> 'eligible' OR "participant_count" >= 2),
+  CONSTRAINT "JourneyCAEEligibility_total_distance_nonneg"
+    CHECK ("total_distance_km" >= 0),
+  CONSTRAINT "JourneyCAEEligibility_eligible_distance_positive"
+    CHECK ("status" <> 'eligible' OR "total_distance_km" > 0),
+  CONSTRAINT "JourneyCAEEligibility_c_factor_positive"
+    CHECK ("c_factor_used" > 0),
+  CONSTRAINT "JourneyCAEEligibility_cef_ref_positive"
+    CHECK ("cef_ref_used" > 0),
+  CONSTRAINT "JourneyCAEEligibility_eligible_requires_origin"
+    CHECK ("status" <> 'eligible' OR "origin_snapshot" IS NOT NULL),
+  CONSTRAINT "JourneyCAEEligibility_eligible_requires_destination"
+    CHECK ("status" <> 'eligible' OR "destination_snapshot" IS NOT NULL),
+  CONSTRAINT "JourneyCAEEligibility_eligible_requires_vehicle"
+    CHECK ("status" <> 'eligible' OR "vehicle_snapshot" IS NOT NULL),
+  CONSTRAINT "JourneyCAEEligibility_ineligible_has_reasons"
+    CHECK ("status" <> 'ineligible'
+           OR (
+                "ineligibility_reasons" IS NOT NULL
+                AND array_length("ineligibility_reasons", 1) >= 1
+              )),
+  CONSTRAINT "JourneyCAEEligibility_regulation_version_nonempty"
+    CHECK (length(trim("regulation_version")) > 0)
+);
+
+ALTER TABLE "public"."JourneyCAEEligibility" ENABLE ROW LEVEL SECURITY;
+
+-- journey_validation_summary_id is already indexed by the UNIQUE constraint above.
+CREATE INDEX "JourneyCAEEligibility_status_idx"
+  ON "public"."JourneyCAEEligibility" ("status");
+
+-- 2. JourneyParticipantCAEEligibility — one row per participant per journey.
+-- Identity & session fields are promoted from jsonb to typed columns so the
+-- audit export reads them directly (no fragile `->>` casts) and so the
+-- frozen audit truth survives a profile delete (GDPR erasure → user_id goes
+-- NULL while dni_nie/surname/etc. remain intact).
+CREATE TABLE "public"."JourneyParticipantCAEEligibility" (
+  "id" uuid NOT NULL DEFAULT gen_random_uuid(),
+  "journey_cae_eligibility_id" uuid NOT NULL,
+  -- Nullable: SET NULL on profile delete to satisfy GDPR while keeping the
+  -- audit row immutable. The promoted typed columns below are the truth.
+  "user_id" uuid,
+  "eligible" boolean NOT NULL,
+  "role" text NOT NULL
+    CHECK ("role" IN ('driver', 'passenger')),
+  "distance_km" numeric NOT NULL,
+  "energy_saved_kwh" numeric,
+  "ineligibility_reasons" text[],
+  -- Promoted identity fields (nullable for ineligible rows; required when eligible).
+  "dni_nie" text,
+  "surname" text,
+  "full_name" text,
+  "phone" text,
+  -- Promoted session times (nullable for ineligible rows; joined_at required when eligible).
+  "joined_at" timestamp with time zone,
+  "left_at" timestamp with time zone,
+  -- Frozen snapshot of Profile.cae_consent_accepted_at at decision time.
+  "consent_accepted_at" timestamp with time zone,
+  "created_at" timestamp with time zone NOT NULL DEFAULT now(),
+  CONSTRAINT "JourneyParticipantCAEEligibility_pkey" PRIMARY KEY ("id"),
+  CONSTRAINT "JourneyParticipantCAEEligibility_journey_cae_eligibility_id_fkey"
+    FOREIGN KEY ("journey_cae_eligibility_id")
+      REFERENCES "public"."JourneyCAEEligibility"("id") ON DELETE CASCADE,
+  CONSTRAINT "JourneyParticipantCAEEligibility_user_id_fkey"
+    FOREIGN KEY ("user_id") REFERENCES "public"."Profile"("id") ON DELETE SET NULL,
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligibility_user_key"
+    UNIQUE ("journey_cae_eligibility_id", "user_id"),
+  -- Domain CHECKs.
+  CONSTRAINT "JourneyParticipantCAEEligibility_distance_nonneg"
+    CHECK ("distance_km" >= 0),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_distance_positive"
+    CHECK ("eligible" = false OR "distance_km" > 0),
+  CONSTRAINT "JourneyParticipantCAEEligibility_energy_nonneg"
+    CHECK ("energy_saved_kwh" IS NULL OR "energy_saved_kwh" >= 0),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_requires_energy"
+    CHECK ("eligible" = false OR "energy_saved_kwh" IS NOT NULL),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_requires_dni_nie"
+    CHECK ("eligible" = false OR "dni_nie" IS NOT NULL),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_requires_surname"
+    CHECK ("eligible" = false OR "surname" IS NOT NULL),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_requires_joined_at"
+    CHECK ("eligible" = false OR "joined_at" IS NOT NULL),
+  CONSTRAINT "JourneyParticipantCAEEligibility_session_window_consistent"
+    CHECK ("left_at" IS NULL OR "joined_at" IS NULL OR "left_at" >= "joined_at"),
+  CONSTRAINT "JourneyParticipantCAEEligibility_eligible_requires_consent"
+    CHECK ("eligible" = false OR "consent_accepted_at" IS NOT NULL),
+  CONSTRAINT "JourneyParticipantCAEEligibility_ineligible_has_reasons"
+    CHECK ("eligible" = true
+           OR (
+                "ineligibility_reasons" IS NOT NULL
+                AND array_length("ineligibility_reasons", 1) >= 1
+              ))
+);
+
+ALTER TABLE "public"."JourneyParticipantCAEEligibility" ENABLE ROW LEVEL SECURITY;
+
+CREATE INDEX "JourneyParticipantCAEEligibility_user_id_idx"
+  ON "public"."JourneyParticipantCAEEligibility" ("user_id");
+
+-- 3. Profile.cae_consent_accepted_at — user-level CAE consent timestamp
+-- NULL = not accepted. Non-null = accepted at this time.
+-- Required for a participant to be CAE-eligible (per TRA040 informed-consent rule).
+ALTER TABLE "public"."Profile"
+  ADD COLUMN "cae_consent_accepted_at" timestamp with time zone;
+
+-- Server-side guard against client-set consent timestamps.
+-- Transitions allowed:
+--   NULL          -> NULL          (no-op)
+--   NULL          -> NOT NULL      (accept; value forced to now())
+--   NOT NULL      -> NULL          (revoke)
+--   NOT NULL      -> NOT NULL      (frozen; client cannot rewrite the timestamp)
+CREATE OR REPLACE FUNCTION enforce_cae_consent_timestamp()
+RETURNS TRIGGER LANGUAGE plpgsql AS $$
+BEGIN
+  IF OLD.cae_consent_accepted_at IS NULL
+     AND NEW.cae_consent_accepted_at IS NOT NULL THEN
+    NEW.cae_consent_accepted_at := now();
+  ELSIF OLD.cae_consent_accepted_at IS NOT NULL
+     AND NEW.cae_consent_accepted_at IS NOT NULL THEN
+    NEW.cae_consent_accepted_at := OLD.cae_consent_accepted_at;
+  END IF;
+  RETURN NEW;
+END;
+$$;
+
+CREATE TRIGGER enforce_cae_consent_timestamp
+  BEFORE UPDATE OF cae_consent_accepted_at ON "public"."Profile"
+  FOR EACH ROW EXECUTE FUNCTION enforce_cae_consent_timestamp();
diff --git a/packages/supabase/supabase/migrations/20260512140100_core_1995_cae_eligibility_rls.sql b/packages/supabase/supabase/migrations/20260512140100_core_1995_cae_eligibility_rls.sql
new file mode 100644
index 000000000..c2f73e9fe
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512140100_core_1995_cae_eligibility_rls.sql
@@ -0,0 +1,86 @@
+-- CORE-1995: RLS for JourneyCAEEligibility and JourneyParticipantCAEEligibility
+-- Mirrors the CORE-1993 pattern (journey owner or participant can SELECT;
+-- service_role has full access). Writes happen exclusively from
+-- ride_evaluate_cae_eligibility (CORE-1996) running as SECURITY DEFINER.
+
+-- ============================================================
+-- JourneyCAEEligibility RLS
+-- ============================================================
+REVOKE ALL ON "public"."JourneyCAEEligibility" FROM public, anon, authenticated;
+GRANT SELECT ON "public"."JourneyCAEEligibility" TO authenticated;
+GRANT ALL ON "public"."JourneyCAEEligibility" TO service_role;
+
+CREATE POLICY "Journey owner or participant can read JourneyCAEEligibility"
+  ON "public"."JourneyCAEEligibility"
+  FOR SELECT
+  TO authenticated
+  USING (
+    EXISTS (
+      SELECT 1 FROM "public"."JourneyValidationSummary" jvs
+      JOIN "public"."Journey" j ON j.id = jvs.journey_id
+      JOIN "public"."Ride" r ON r.id = j.ride_id
+      WHERE jvs.id = "JourneyCAEEligibility"."journey_validation_summary_id"
+        AND (
+          r.owner_id = (SELECT auth.uid())
+          OR EXISTS (
+            SELECT 1 FROM "public"."RideParticipant" rp
+            WHERE rp.ride_id = r.id
+              AND rp.profile_id = (SELECT auth.uid())
+          )
+        )
+    )
+  );
+
+CREATE POLICY "Service role full access JourneyCAEEligibility"
+  ON "public"."JourneyCAEEligibility"
+  FOR ALL
+  TO service_role
+  USING (true)
+  WITH CHECK (true);
+
+-- ============================================================
+-- JourneyParticipantCAEEligibility RLS
+-- ============================================================
+REVOKE ALL ON "public"."JourneyParticipantCAEEligibility" FROM public, anon, authenticated;
+GRANT SELECT ON "public"."JourneyParticipantCAEEligibility" TO authenticated;
+GRANT ALL ON "public"."JourneyParticipantCAEEligibility" TO service_role;
+
+-- A user can always read their own CAE participant row (regardless of
+-- whether they're still on the journey's participant list).
+CREATE POLICY "User can read own JourneyParticipantCAEEligibility"
+  ON "public"."JourneyParticipantCAEEligibility"
+  FOR SELECT
+  TO authenticated
+  USING ("user_id" = (SELECT auth.uid()));
+
+-- Journey owner can read all participant rows for their journey (used for the
+-- post-journey "who got CAEs?" view shown only to the driver).
+-- Note: passengers can only read their OWN row (policy above). Cross-
+-- participant reads are intentionally NOT permitted because the typed
+-- columns (dni_nie, surname, phone) are CAE audit PII that does not need
+-- to be visible to co-passengers.
+CREATE POLICY "Journey owner can read participants JourneyParticipantCAEEligibility"
+  ON "public"."JourneyParticipantCAEEligibility"
+  FOR SELECT
+  TO authenticated
+  USING (
+    EXISTS (
+      SELECT 1 FROM "public"."JourneyCAEEligibility" jce
+      JOIN "public"."JourneyValidationSummary" jvs ON jvs.id = jce.journey_validation_summary_id
+      JOIN "public"."Journey" j ON j.id = jvs.journey_id
+      JOIN "public"."Ride" r ON r.id = j.ride_id
+      WHERE jce.id = "journey_cae_eligibility_id"
+        AND r.owner_id = (SELECT auth.uid())
+    )
+  );
+
+CREATE POLICY "Service role full access JourneyParticipantCAEEligibility"
+  ON "public"."JourneyParticipantCAEEligibility"
+  FOR ALL
+  TO service_role
+  USING (true)
+  WITH CHECK (true);
+
+-- Note: Profile.cae_consent_accepted_at uses the existing Profile RLS
+-- (users can SELECT/UPDATE their own row). No policy change required here.
+-- The SDK acceptCAEConsent/revokeCAEConsent methods land in CORE-1997.
diff --git a/packages/supabase/supabase/migrations/20260512140200_core_1995_cae_audit_export_view.sql b/packages/supabase/supabase/migrations/20260512140200_core_1995_cae_audit_export_view.sql
new file mode 100644
index 000000000..cc53db57d
--- /dev/null
+++ b/packages/supabase/supabase/migrations/20260512140200_core_1995_cae_audit_export_view.sql
@@ -0,0 +1,63 @@
+-- CORE-1995: cae_audit_export — service-role-only view feeding delCAU exports
+-- One row per eligible participant on a certified journey.
+-- Filters: JourneyValidationSummary.status = 'passed' AND JourneyCAEEligibility.status = 'eligible'
+-- AND JourneyParticipantCAEEligibility.eligible = true.
+
+-- NOTE: do NOT JOIN "Profile" here to backfill names/phones. The typed
+-- columns on JourneyParticipantCAEEligibility (dni_nie, surname, full_name,
+-- phone, joined_at, left_at, consent_accepted_at) are the frozen audit
+-- truth. Joining Profile would re-introduce live drift this design exists
+-- to prevent — and would surface PII for users who later revoked or were
+-- erased.
+CREATE OR REPLACE VIEW "public"."cae_audit_export" AS
+SELECT
+  -- Journey-level (journey_id sourced from JourneyValidationSummary, the single source of truth)
+  jvs."journey_id",
+  jce."decided_at",
+  jce."ficha",
+  jce."is_long_distance",
+  jce."participant_count",
+  jce."total_distance_km",
+  jce."regulation_version",
+  jce."c_factor_used",
+  jce."cef_ref_used",
+  jce."origin_snapshot",
+  jce."destination_snapshot",
+  jce."vehicle_snapshot",
+  -- Participant identity (frozen at decision time, typed columns)
+  jpce."user_id",
+  jpce."role",
+  jpce."distance_km",
+  jpce."energy_saved_kwh",
+  jpce."dni_nie",
+  jpce."surname",
+  jpce."full_name",
+  jpce."phone",
+  -- Session times (frozen at decision time, typed columns)
+  jpce."joined_at",
+  jpce."left_at",
+  jpce."consent_accepted_at",
+  -- Verdict reference (always 'passed' here, kept for traceability)
+  jvs."status"        AS "journey_validation_status",
+  jvs."validated_at"  AS "journey_validation_validated_at"
+FROM "public"."JourneyCAEEligibility" jce
+JOIN "public"."JourneyValidationSummary" jvs
+  ON jvs."id" = jce."journey_validation_summary_id"
+JOIN "public"."JourneyParticipantCAEEligibility" jpce
+  ON jpce."journey_cae_eligibility_id" = jce."id"
+WHERE jvs."status" = 'passed'
+  AND jce."status" = 'eligible'
+  AND jpce."eligible" = true;
+
+-- security_invoker forces the view to honor the caller's RLS on underlying
+-- tables (PG 15+). Without it, the view runs as its owner (typically
+-- postgres) and bypasses RLS — unsafe for an audit-export view.
+ALTER VIEW "public"."cae_audit_export" SET (security_invoker = on);
+
+-- Service-role-only access.
+REVOKE ALL ON "public"."cae_audit_export" FROM public, anon, authenticated;
+GRANT SELECT ON "public"."cae_audit_export" TO service_role;
+
+COMMENT ON VIEW "public"."cae_audit_export" IS
+  'CAE audit export: one row per eligible participant on a certified journey. '
+  'service_role only — feeds delCAU manual exports and the independent annual audit.';
